# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://prospector:prospector_dev@localhost:5432/prospector

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── AI (DeepSeek) ─────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=sk-...

# ── Evolution API (WhatsApp) ─────────────────────────────────────────────────
EVOLUTION_API_URL=https://sua-evolution-api.com
EVOLUTION_API_KEY=sua-api-key
EVOLUTION_INSTANCE=nome-da-instancia

# ── Scraping ─────────────────────────────────────────────────────────────────
# Cidades para prospectar (separadas por vírgula)
TARGET_CITIES=São Paulo,Campinas,Guarulhos
# Nicho(s) alvo (separados por vírgula — deixe vazio para todos)
TARGET_NICHES=oficina,clinica,restaurante,academia,imoveis,estetica

# ── Rate Limits ──────────────────────────────────────────────────────────────
WHATSAPP_MIN_DELAY_MS=120000
WHATSAPP_MAX_DELAY_MS=600000
WHATSAPP_MAX_PER_HOUR=8
SCRAPE_MAX_LEADS_PER_RUN=50

# ── Paths ────────────────────────────────────────────────────────────────────
OUTPUT_DIR=./output
SCREENSHOTS_DIR=./output/screenshots
PAGES_DIR=./output/pages

# ── Dashboard ────────────────────────────────────────────────────────────────
DASHBOARD_PORT=3000
# Se DASHBOARD_PASSWORD for definido, o dashboard exige HTTP Basic Auth
DASHBOARD_USER=admin
# DASHBOARD_PASSWORD=senha-segura

# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
