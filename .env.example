# ── Database ────────────────────────────────────────────────────────────────
# Porta 5433 para não conflitar com outros containers Postgres na máquina
DATABASE_URL=postgresql://prospector:prospector_dev@localhost:5433/prospector

# ── Redis ────────────────────────────────────────────────────────────────────
# Porta 6381 para não conflitar com outros containers Redis na máquina
REDIS_URL=redis://localhost:6381

# ── AI (DeepSeek) ─────────────────────────────────────────────────────────────
# OBRIGATÓRIO — obtenha em https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-...

# ── Evolution API (WhatsApp) ─────────────────────────────────────────────────
# OBRIGATÓRIO — URL da sua instância Evolution API (ex: http://localhost:8081)
EVOLUTION_API_URL=https://sua-evolution-api.com
# OBRIGATÓRIO — chave de API gerada no painel da Evolution
EVOLUTION_API_KEY=sua-api-key
# OBRIGATÓRIO — nome da instância WhatsApp criada na Evolution (ex: Rafael)
EVOLUTION_INSTANCE=nome-da-instancia

# ── Scraping ─────────────────────────────────────────────────────────────────
# Cidades para prospectar (separadas por vírgula)
TARGET_CITIES=São Paulo,Campinas,Guarulhos
# Nicho(s) alvo (separados por vírgula — deixe vazio para todos)
TARGET_NICHES=oficina,clinica,restaurante,academia,imoveis,estetica

# ── Rate Limits ──────────────────────────────────────────────────────────────
WHATSAPP_MIN_DELAY_MS=120000
WHATSAPP_MAX_DELAY_MS=600000
WHATSAPP_MAX_PER_HOUR=8
SCRAPE_MAX_LEADS_PER_RUN=50

# ── Paths ────────────────────────────────────────────────────────────────────
OUTPUT_DIR=./output
SCREENSHOTS_DIR=./output/screenshots
PAGES_DIR=./output/pages

# ── Dashboard ────────────────────────────────────────────────────────────────
DASHBOARD_PORT=3000
DASHBOARD_USER=admin
# Opcional — se definido, o dashboard exige HTTP Basic Auth
# DASHBOARD_PASSWORD=senha-segura

# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
